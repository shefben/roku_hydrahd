<?xml version="1.0" encoding="utf-8" ?>
<component name="DetailsView" extends="Group">
    <interface>
        <field id="args" type="assocarray" onChange="onArgs" />
        <field id="requestNav" type="assocarray" alwaysNotify="true" />
        <field id="loading" type="bool" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/DetailsView.brs" />
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/Watchlist.brs" />

    <children>
        <Poster id="backdrop" translation="[0,0]" width="1920" height="540" loadDisplayMode="scaleToFill"
                opacity="0.45" />
        <Rectangle width="1920" height="540" color="0x0a0a0acc" />

        <LayoutGroup translation="[60, 20]" layoutDirection="horiz" itemSpacings="[40]">
            <Poster id="poster" width="280" height="380" loadDisplayMode="scaleToZoom"
                    failedBitmapUri="pkg:/images/placeholder.png" />
            <LayoutGroup layoutDirection="vert" itemSpacings="[8]" translation="[0, 10]">
                <Label id="title" text="" font="font:LargeBoldSystemFont" color="0xffffffff" width="1540" maxLines="2" />
                <Label id="meta" text="" font="font:MediumSystemFont" color="0xb8b8b8ff" />
                <Label id="genres" text="" font="font:SmallSystemFont" color="0xff8a8aff" />
                <Label id="overview" text="" font="font:MediumSystemFont" color="0xeeeeeeff" width="1540" wrap="true" maxLines="4" />
                <Label id="cast" text="" font="font:SmallSystemFont" color="0xc8c8c8ff" width="1540" maxLines="1" />

                <ButtonGroup id="actions" translation="[0, 8]"
                             layoutDirection="horiz" itemSpacings="[18]"
                             minWidth="200" />
                <Label id="status2" text="" font="font:SmallSystemFont" color="0xffd24aff" width="1540" maxLines="1" />
            </LayoutGroup>
        </LayoutGroup>

        <Group id="seasonGroup" translation="[60, 420]" visible="false">
            <Label id="seasonTitle" text="Seasons" font="font:LargeBoldSystemFont" color="0xffffffff" />
            <MarkupGrid id="seasonRow" translation="[0, 40]"
                        itemSize="[170, 60]"
                        numRows="1"
                        numColumns="9"
                        itemSpacing="[10, 0]"
                        itemComponentName="SeasonChip"
                        drawFocusFeedback="true"
                        drawFocusFeedbackOnTop="true" />
            <MarkupGrid id="episodeGrid"
                        translation="[0, 120]"
                        itemSize="[1750, 130]"
                        numColumns="1"
                        numRows="3"
                        itemSpacing="[0, 12]"
                        vertFocusAnimationStyle="floatingFocus"
                        drawFocusFeedback="true"
                        drawFocusFeedbackOnTop="true" />
        </Group>
    </children>
</component>
