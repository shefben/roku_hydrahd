<?xml version="1.0" encoding="utf-8" ?>
<component name="DetailsView" extends="Group">
    <interface>
        <field id="args" type="assocarray" onChange="onArgs" />
        <field id="requestNav" type="assocarray" alwaysNotify="true" />
        <field id="loading" type="bool" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/DetailsView.brs" />
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />

    <children>
        <Poster id="backdrop" translation="[0,0]" width="1920" height="700" loadDisplayMode="scaleToFill"
                opacity="0.45" />
        <Rectangle width="1920" height="700" color="0x0a0a0acc" />

        <LayoutGroup translation="[60, 20]" layoutDirection="horiz" itemSpacings="[40]">
            <Poster id="poster" width="320" height="475" loadDisplayMode="scaleToZoom"
                    failedBitmapUri="pkg:/images/placeholder.png" />
            <LayoutGroup layoutDirection="vert" itemSpacings="[10]" translation="[0, 20]">
                <Label id="title" text="" font="font:LargeBoldSystemFont" color="0xffffffff" width="1500" maxLines="2" />
                <Label id="meta" text="" font="font:MediumSystemFont" color="0xb8b8b8ff" />
                <Label id="genres" text="" font="font:SmallSystemFont" color="0xff8a8aff" />
                <Label id="overview" text="" font="font:MediumSystemFont" color="0xeeeeeeff" width="1500" wrap="true" maxLines="6" />
                <Label id="cast" text="" font="font:SmallSystemFont" color="0xc8c8c8ff" width="1500" maxLines="2" />

                <ButtonGroup id="actions" translation="[0, 20]"
                             layoutDirection="horiz" itemSpacings="[18]"
                             minWidth="200" />
                <Label id="status2" text="" font="font:SmallSystemFont" color="0x9a9a9aff" />
            </LayoutGroup>
        </LayoutGroup>

        <Group id="seasonGroup" translation="[60, 540]" visible="false">
            <Label id="seasonTitle" text="Seasons" font="font:LargeBoldSystemFont" color="0xffffffff" />
            <ButtonGroup id="seasonRow" translation="[0, 40]"
                         layoutDirection="horiz" itemSpacings="[10]" minWidth="140" />
            <MarkupGrid id="episodeGrid"
                        translation="[0, 110]"
                        itemSize="[420, 130]"
                        numColumns="4"
                        numRows="3"
                        itemSpacing="[16, 16]"
                        drawFocusFeedback="true"
                        drawFocusFeedbackOnTop="true" />
        </Group>

        <Label id="status" translation="[60, 1010]" text="" font="font:SmallSystemFont" color="0xffd24aff" />
    </children>
</component>
