<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeView" extends="Group">
    <interface>
        <field id="args" type="assocarray" />
        <field id="requestNav" type="assocarray" alwaysNotify="true" />
        <field id="loading" type="bool" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/HomeView.brs" />
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/Watchlist.brs" />
    <script type="text/brightscript" uri="pkg:/source/Sync.brs" />

    <children>
        <!-- Cinematic hero spotlight. Non-focusable: it mirrors whatever
             poster the user has focused in the rows below (backdrop +
             title + meta update on every move), so it reads as a premium
             "featured" banner without adding a separate focus stop. -->
        <Group id="hero">
            <Poster id="heroBackdrop" translation="[0, 0]" width="1920" height="430"
                    loadDisplayMode="scaleToFill" failedBitmapUri="pkg:/images/placeholder.png" />
            <Poster id="heroScrim" translation="[0, 0]" width="1920" height="430"
                    uri="pkg:/images/hero_scrim.png" loadDisplayMode="scaleToFill" />
            <Label id="heroTitle" translation="[70, 250]" width="1160" maxLines="2"
                   text="" font="font:LargeBoldSystemFont" color="0xffffffff" />
            <Label id="heroMeta" translation="[70, 348]" width="1160" maxLines="1"
                   text="" font="font:MediumSystemFont" color="0xd0d0d0ff" />
            <Label id="heroHint" translation="[70, 388]" width="1160" maxLines="1"
                   text="OK to open  -  LEFT/RIGHT to browse  -  UP for menu"
                   font="font:SmallestSystemFont" color="0x9a9a9aff" />
        </Group>

        <!-- One row visible at a time beneath the hero; UP/DOWN moves
             between rows and the hero follows the focused tile. -->
        <RowList id="rows"
                 translation="[60, 452]"
                 itemSize="[1800, 470]"
                 numRows="1"
                 rowItemSize="[[220, 380]]"
                 rowItemSpacing="[[20, 0]]"
                 rowSpacings="[20]"
                 rowFocusAnimationStyle="floatingFocus"
                 showRowLabel="[true]"
                 showRowCounter="[false]"
                 rowLabelOffset="[[0, 0]]"
                 rowLabelFont="font:MediumBoldSystemFont"
                 rowLabelColor="0xffffffff"
                 focusXOffset="0" />

        <Label id="empty" translation="[70, 250]" width="1600" wrap="true"
               text="No content. Pull-to-refresh by pressing OK."
               font="font:MediumSystemFont" color="0x808080ff" visible="false" />
    </children>
</component>
