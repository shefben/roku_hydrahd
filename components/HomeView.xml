<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeView" extends="Group">
    <interface>
        <field id="args" type="assocarray" />
        <field id="requestNav" type="assocarray" alwaysNotify="true" />
        <field id="loading" type="bool" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/HomeView.brs" />
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/Watchlist.brs" />

    <children>
        <!-- 4 rows visible at once. Cells are ~half the linear size of
             the original (poster 110x165 + ~35px text below = 200 tall),
             which is roughly 1/4 the screen area each. itemSize.y is
             cell + label-row gap. floatingFocus keeps labels glued to
             rows so they don't appear at "random" y positions. -->
        <RowList id="rows"
                 translation="[60, 20]"
                 itemSize="[1800, 230]"
                 numRows="4"
                 rowItemSize="[[110, 200]]"
                 rowItemSpacing="[[10, 0]]"
                 rowSpacings="[10]"
                 rowFocusAnimationStyle="floatingFocus"
                 showRowLabel="[true]"
                 showRowCounter="[false]"
                 rowLabelOffset="[[0, 0]]"
                 rowLabelFont="font:SmallBoldSystemFont"
                 rowLabelColor="0xffffffff"
                 focusXOffset="0" />

        <Label id="empty" translation="[60, 400]" text="No content. Pull-to-refresh by pressing OK."
               font="font:MediumSystemFont" color="0x808080ff" visible="false" />
    </children>
</component>
