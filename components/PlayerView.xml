<?xml version="1.0" encoding="utf-8" ?>
<component name="PlayerView" extends="Group">
    <interface>
        <field id="args" type="assocarray" onChange="onArgs" alwaysNotify="true" />
        <field id="requestNav" type="assocarray" alwaysNotify="true" />
        <field id="loading" type="bool" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/PlayerView.brs" />
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/Watchlist.brs" />
    <script type="text/brightscript" uri="pkg:/source/Sync.brs" />

    <children>
        <Video id="video" width="1920" height="1080" enableUI="true" enableTrickPlay="true" />

        <Rectangle id="overlayBg" width="1920" height="1080" color="0x000000aa" visible="false" />

        <!-- Netflix-style skip prompt at the bottom-right corner of the
             1920x1080 frame: ~80px in from each edge. Two visual modes:
             intro/recap show "Skip Intro"/"Skip Recap" and fade after
             5 seconds; outros (TV episodes only, and only when the
             queue has another episode after the current one) show
             "Play Next Episode" with a 5-second progress bar that
             auto-advances unless the user presses BACK or OK. -->
        <Group id="skipBanner" translation="[1500, 936]" visible="false" opacity="1.0">
            <!-- Layered rectangles fake a 2px white outline since
                 Roku's Rectangle has no native stroke property. -->
            <Rectangle width="340" height="64" color="0xffffffff" opacity="0.85" />
            <Rectangle translation="[2, 2]" width="336" height="60" color="0x141414f0" />
            <Label id="skipLabel" translation="[20, 12]" width="300" height="36" text=""
                   font="font:MediumBoldSystemFont" color="0xffffffff"
                   horizAlign="center" vertAlign="center" />
            <!-- Outro countdown bar. Hidden for intro/recap. -->
            <Group id="skipCountdown" translation="[20, 54]" visible="false">
                <Rectangle width="300" height="4" color="0x66666688" />
                <Rectangle id="skipCountdownFill" width="0" height="4" color="0xe50914ff" />
            </Group>
        </Group>

        <!-- Drives banner state. 5 seconds for intro/recap (then we
             trigger the fade animation) and for outros (then we
             auto-advance to the next episode). -->
        <Timer id="skipBannerTimer" duration="5.0" repeat="false" />

        <!-- 0.5s opacity fade-out for intro/recap banners. -->
        <Animation id="skipFadeAnim" duration="0.5" easeFunction="outQuad" repeat="false">
            <FloatFieldInterpolator
                key="[0.0, 1.0]"
                keyValue="[1.0, 0.0]"
                fieldToInterp="skipBanner.opacity" />
        </Animation>

        <!-- 5s linear fill (0 -> 300px) for the outro countdown bar. -->
        <Animation id="skipCountdownAnim" duration="5.0" easeFunction="linear" repeat="false">
            <FloatFieldInterpolator
                key="[0.0, 1.0]"
                keyValue="[0.0, 300.0]"
                fieldToInterp="skipCountdownFill.width" />
        </Animation>

        <!-- Time-based "Skip to Next Episode" prompt. Appears 2 m 15 s
             before the end of any TV episode that has a queued
             successor, regardless of whether the resolver detected
             chapter data (works on every mirror / host). The floating
             banner hides after 10 s; the options-menu action bar keeps
             an entry for the rest of the episode. -->
        <Group id="nextEpBanner" translation="[1500, 936]" visible="false">
            <Rectangle width="360" height="64" color="0xffffffff" opacity="0.85" />
            <Rectangle translation="[2, 2]" width="356" height="60" color="0x141414f0" />
            <Label translation="[20, 12]" width="320" height="36"
                   text="Skip to Next Episode"
                   font="font:MediumBoldSystemFont" color="0xffffffff"
                   horizAlign="center" vertAlign="center" />
        </Group>
        <Timer id="nextEpTimer" duration="10.0" repeat="false" />

        <!-- "Loading next episode..." overlay used during in-place
             episode advance. Stays inside PlayerView so the user
             never bounces back to MirrorPicker. -->
        <Group id="advanceOverlay" translation="[600, 460]" visible="false">
            <Rectangle width="720" height="160" color="0x000000ee" />
            <Rectangle translation="[2, 2]" width="716" height="156" color="0x141414ff" />
            <Label id="advanceTitle" translation="[40, 36]" width="640" height="32" text="Loading next episode..."
                   font="font:MediumBoldSystemFont" color="0xffffffff" horizAlign="center" />
            <Label id="advanceStatus" translation="[40, 86]" width="640" height="28" text=""
                   font="font:SmallSystemFont" color="0xffd24aff" horizAlign="center" />
        </Group>

        <LayoutGroup id="overlay" translation="[120, 120]" layoutDirection="vert" itemSpacings="[18]" visible="false">
            <Label id="title" text="" font="font:LargeBoldSystemFont" color="0xffffffff" width="1680" maxLines="1" />
            <Label id="subtitle" text="" font="font:MediumSystemFont" color="0xc8c8c8ff" width="1680" maxLines="1" />

            <!-- Buttons populated dynamically in PlayerView.brs so we
                 can prepend a Skip Intro / Skip Recap / Play Next
                 Episode entry while the playhead is inside a chapter
                 window. See rebuildActionBar(). minWidth here is the
                 per-button minimum (ButtonGroup convention) - long
                 labels like "Play Next Episode" expand past it. -->
            <ButtonGroup id="actionBar" layoutDirection="horiz" itemSpacings="[20]" minWidth="200" />

            <Label id="status" text="" font="font:SmallSystemFont" color="0xffd24aff" width="1680" maxLines="2" />

            <Group id="qualityPanel" visible="false">
                <Label text="Pick a quality - up arrow returns to toolbar" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <LabelList id="qualityRow" translation="[0, 36]" itemSize="[420, 48]" numRows="6" drawFocusFeedback="true" />
            </Group>

            <Group id="ccPanel" visible="false">
                <Label text="Pick a subtitle track - up arrow returns to toolbar" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <LabelList id="ccRow" translation="[0, 36]" itemSize="[520, 48]" numRows="8" drawFocusFeedback="true" />
            </Group>

            <Group id="ccStylePanel" visible="false">
                <Label text="Caption Style - up arrow returns to toolbar" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <LabelList id="ccStyleRow" translation="[0, 36]" itemSize="[420, 48]" numRows="9" drawFocusFeedback="true" />
            </Group>

            <Group id="audioPanel" visible="false">
                <Label text="Pick an audio track - up arrow returns to toolbar" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <LabelList id="audioRow" translation="[0, 36]" itemSize="[420, 48]" numRows="6" drawFocusFeedback="true" />
            </Group>
        </LayoutGroup>
    </children>
</component>
