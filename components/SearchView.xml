<?xml version="1.0" encoding="utf-8" ?>
<component name="SearchView" extends="Group">
    <interface>
        <field id="args" type="assocarray" />
        <field id="requestNav" type="assocarray" alwaysNotify="true" />
        <field id="loading" type="bool" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/SearchView.brs" />
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />

    <children>
        <Label id="title" translation="[60, 10]" text="Search" font="font:LargeBoldSystemFont" color="0xffffffff" />

        <LayoutGroup translation="[60, 70]" layoutDirection="horiz" itemSpacings="[40]">
            <Group>
                <Keyboard id="kb" translation="[0,0]" />
                <Label id="kbHint" translation="[0, 320]" text="Press OK on Search after typing"
                       font="font:SmallSystemFont" color="0x808080ff" />
                <Button id="searchBtn" translation="[0, 360]" text="Search" minWidth="180" />
            </Group>

            <Group translation="[40, 0]">
                <Label id="resultTitle" text="Results" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <MarkupGrid id="grid" translation="[0, 30]"
                            itemSize="[230, 380]"
                            numColumns="5"
                            numRows="2"
                            itemSpacing="[16, 24]"
                            vertFocusAnimationStyle="fixedFocusWrap"
                            drawFocusFeedback="true"
                            drawFocusFeedbackOnTop="true" />
                <Label id="empty" translation="[0, 80]" text="" font="font:MediumSystemFont"
                       color="0x808080ff" visible="false" />
            </Group>
        </LayoutGroup>
    </children>
</component>
