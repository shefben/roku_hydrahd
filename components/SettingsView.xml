<?xml version="1.0" encoding="utf-8" ?>
<component name="SettingsView" extends="Group">
    <interface>
        <field id="args" type="assocarray" />
        <field id="requestNav" type="assocarray" alwaysNotify="true" />
        <field id="loading" type="bool" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/SettingsView.brs" />
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />

    <children>
        <Label translation="[60, 10]" text="Settings" font="font:LargeBoldSystemFont" color="0xffffffff" />

        <LayoutGroup id="layoutGroup" translation="[60, 80]" layoutDirection="vert" itemSpacings="[28]">
            <Group>
                <Label text="Base URL" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <Label id="baseUrlValue" translation="[0, 30]" text="" font="font:SmallSystemFont" color="0xc8c8c8ff" width="1500" />
                <ButtonGroup id="baseRow" translation="[0, 60]" layoutDirection="horiz" itemSpacings="[12]" minWidth="220" />
            </Group>

            <Group>
                <Label text="TMDB API Key (richer info)" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <Label translation="[0, 34]" width="1760" wrap="true" maxLines="2"
                       text="Optional free key from themoviedb.org. Adds real plot synopsis, ratings, cast photos and HD artwork to detail pages."
                       font="font:SmallSystemFont" color="0x9a9a9aff" />
                <Label id="tmdbValue" translation="[0, 86]" text="" font="font:SmallSystemFont" color="0xc8c8c8ff" />
                <ButtonGroup id="tmdbRow" translation="[0, 118]" layoutDirection="horiz" itemSpacings="[12]" minWidth="170" />
            </Group>

            <Group>
                <Label text="In-Channel Resolver (experimental)" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <Label id="inChannelHelp" translation="[0, 34]" width="1760" wrap="true" maxLines="2"
                       text="Resolve mirror URLs inside the channel - no LAN host needed. Falls back to the resolver URL below."
                       font="font:SmallSystemFont" color="0x9a9a9aff" />
                <Label id="inChannelValue" translation="[0, 86]" text="" font="font:SmallSystemFont" color="0xc8c8c8ff" />
                <ButtonGroup id="inChannelRow" translation="[0, 118]" layoutDirection="horiz" itemSpacings="[12]" minWidth="170" />
            </Group>

            <Group>
                <Label text="External Resolver URL (fallback)" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <Label id="resolverHelp" translation="[0, 34]" width="1760" wrap="true" maxLines="2"
                       text="Fallback when in-channel fails. Run resolver/server.py on a LAN host (auto-discovered) or set a cloud URL."
                       font="font:SmallSystemFont" color="0x9a9a9aff" />
                <Label id="resolverValue" translation="[0, 86]" text="" font="font:SmallSystemFont" color="0xc8c8c8ff" />
                <ButtonGroup id="resolverRow" translation="[0, 118]" layoutDirection="horiz" itemSpacings="[12]" minWidth="220" />
                <Label id="resolverStatus" translation="[0, 170]" text="" font="font:SmallSystemFont" color="0x9affa0ff" />
            </Group>

            <Group>
                <Label text="Captions" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <Label translation="[0, 30]" text="Choose default size, text color, and background - applied to every video."
                       font="font:SmallSystemFont" color="0x9a9a9aff" />
                <ButtonGroup id="ccSizeRow" translation="[0, 60]" layoutDirection="horiz" itemSpacings="[12]" minWidth="170" />
                <ButtonGroup id="ccColorRow" translation="[0, 110]" layoutDirection="horiz" itemSpacings="[12]" minWidth="170" />
                <ButtonGroup id="ccBgRow" translation="[0, 160]" layoutDirection="horiz" itemSpacings="[12]" minWidth="240" />
                <Rectangle id="ccPreviewBg" translation="[-8, 218]" width="780" height="32" color="0x000000aa" />
                <Label id="ccPreview" translation="[0, 220]" text="The quick brown fox jumps over the lazy dog."
                       font="font:MediumBoldSystemFont" color="0xffffffff" />
            </Group>
        </LayoutGroup>

        <Group id="urlEditGroup" visible="false">
            <Rectangle width="1920" height="1080" color="0x000000d0" />
            <LayoutGroup translation="[300, 200]" layoutDirection="vert" itemSpacings="[20]">
                <Label id="urlEditTitle" text="" font="font:LargeBoldSystemFont" color="0xffffffff" />
                <Keyboard id="urlKb" />
                <ButtonGroup id="urlActionsRow" layoutDirection="horiz" itemSpacings="[14]" minWidth="160" />
            </LayoutGroup>
        </Group>
    </children>
</component>
