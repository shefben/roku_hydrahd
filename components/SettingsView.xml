<?xml version="1.0" encoding="utf-8" ?>
<component name="SettingsView" extends="Group">
    <interface>
        <field id="args" type="assocarray" />
        <field id="requestNav" type="assocarray" alwaysNotify="true" />
        <field id="loading" type="bool" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/SettingsView.brs" />
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />

    <children>
        <Label translation="[60, 10]" text="Settings" font="font:LargeBoldSystemFont" color="0xffffffff" />

        <LayoutGroup translation="[60, 80]" layoutDirection="vert" itemSpacings="[28]">
            <Group>
                <Label text="Base URL" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <Label id="baseUrlValue" translation="[0, 30]" text="" font="font:SmallSystemFont" color="0xc8c8c8ff" width="1500" />
                <LayoutGroup translation="[0, 60]" layoutDirection="horiz" itemSpacings="[12]">
                    <Button id="useDefaultBase" text="Use hydrahd.ru" minWidth="220" />
                    <Button id="editBase" text="Edit URL" minWidth="160" />
                </LayoutGroup>
            </Group>

            <Group>
                <Label text="Stream Resolver URL (optional)" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <Label id="resolverHelp" translation="[0, 30]" width="1700" wrap="true" maxLines="3"
                       text="HydraHD uses third-party iframe embeds. Roku can only play direct video URLs (HLS / MP4). To enable real playback for those mirrors, run the Python resolver in resolver/ on a machine on your network and put its URL here, e.g. http://192.168.1.50:8787"
                       font="font:SmallSystemFont" color="0x9a9a9aff" />
                <Label id="resolverValue" translation="[0, 110]" text="" font="font:SmallSystemFont" color="0xc8c8c8ff" />
                <LayoutGroup translation="[0, 140]" layoutDirection="horiz" itemSpacings="[12]">
                    <Button id="setResolver" text="Set Resolver..." minWidth="220" />
                    <Button id="clearResolver" text="Clear" minWidth="140" />
                </LayoutGroup>
            </Group>

            <Group>
                <Label text="Captions" font="font:MediumBoldSystemFont" color="0xffffffff" />
                <Label translation="[0, 30]" text="Choose default size, text color, and background - applied to every video."
                       font="font:SmallSystemFont" color="0x9a9a9aff" />
                <LayoutGroup translation="[0, 60]" layoutDirection="horiz" itemSpacings="[12]">
                    <Button id="ccSizeSmall" text="Text: Small" minWidth="160" />
                    <Button id="ccSizeMed" text="Text: Medium" minWidth="170" />
                    <Button id="ccSizeLarge" text="Text: Large" minWidth="170" />
                </LayoutGroup>
                <LayoutGroup translation="[0, 110]" layoutDirection="horiz" itemSpacings="[12]">
                    <Button id="ccColorWhite" text="Text: White" minWidth="160" />
                    <Button id="ccColorYellow" text="Text: Yellow" minWidth="170" />
                    <Button id="ccColorCyan" text="Text: Cyan" minWidth="170" />
                </LayoutGroup>
                <LayoutGroup translation="[0, 160]" layoutDirection="horiz" itemSpacings="[12]">
                    <Button id="ccBgBlack" text="BG: Black" minWidth="160" />
                    <Button id="ccBgSemi" text="BG: Semi-Transparent" minWidth="240" />
                    <Button id="ccBgNone" text="BG: None" minWidth="160" />
                </LayoutGroup>
                <Rectangle id="ccPreviewBg" translation="[-8, 218]" width="780" height="32" color="0x000000aa" />
                <Label id="ccPreview" translation="[0, 220]" text="The quick brown fox jumps over the lazy dog."
                       font="font:MediumBoldSystemFont" color="0xffffffff" />
            </Group>
        </LayoutGroup>

        <Group id="urlEditGroup" visible="false">
            <Rectangle width="1920" height="1080" color="0x000000d0" />
            <LayoutGroup translation="[300, 200]" layoutDirection="vert" itemSpacings="[20]">
                <Label id="urlEditTitle" text="" font="font:LargeBoldSystemFont" color="0xffffffff" />
                <Keyboard id="urlKb" />
                <LayoutGroup layoutDirection="horiz" itemSpacings="[14]">
                    <Button id="urlSave" text="Save" minWidth="160" />
                    <Button id="urlCancel" text="Cancel" minWidth="160" />
                </LayoutGroup>
            </LayoutGroup>
        </Group>
    </children>
</component>
