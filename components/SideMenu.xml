<?xml version="1.0" encoding="utf-8" ?>
<component name="SideMenu" extends="Group">
    <interface>
        <!-- Output: parent observes this to react to button presses.
             Payloads are { action: "navTab", tabId: "navHome" },
             { action: "exit" }, or { action: "collapsed" }. -->
        <field id="command" type="assocarray" alwaysNotify="true" />

        <!-- Field-based expand trigger. Parent sets this to true and
             SideMenu observes it to expand the panel + focus the
             first button. Used in place of callFunc("openMenu") so
             we never get burned by callFunc's parameter-arity rules. -->
        <field id="expandRequest" type="bool" value="false" alwaysNotify="true" />

        <!-- Parent calls focusStrip to put focus on the collapsed
             trigger (or the open menu if already expanded). -->
        <function name="focusStrip" />
        <!-- openMenu expands the panel and focuses the first button
             directly. Kept for callers that prefer callFunc; setting
             expandRequest = true is the more robust path. -->
        <function name="openMenu" />
        <function name="isExpanded" />
        <function name="collapseSilent" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/SideMenu.brs" />

    <children>
        <!-- Always-visible thin strip at the leftmost edge. Acts as a
             visual hint that the menu is here even when collapsed. -->
        <Rectangle id="strip" width="6" height="1080" color="0xff2424ff" opacity="0.3" />
        <Label id="stripChevron" translation="[8, 510]" width="20" height="40" text=">"
               font="font:LargeBoldSystemFont" color="0xffffffff"
               horizAlign="left" vertAlign="center" opacity="0.4" />

        <!-- Off-screen Button that absorbs focus and OK on the strip
             without leaking the default Button chrome onto the visible
             strip Rectangle. The strip's brightness is updated based
             on whether this button currently holds focus. -->
        <Button id="stripToggle" translation="[-200, 0]" minWidth="6" text="" />

        <!-- The slide-out panel itself. Hidden (visible=false) AND parked
             fully off-screen at x=-360 when collapsed; animates to x=0 when
             expanded. visible=false guarantees no peek regardless of how
             wide the auto-sized buttons grow (the previous -280 let the
             widest labels - "Browse Movies"/"Browse TV Shows" - poke past
             the left edge). Panel widened to 340 so those labels fit
             inside the panel background instead of overflowing its border. -->
        <!-- Parked fully off-screen at x=-460 when collapsed (panel bg is
             340 wide; -460 hides it AND its widest auto-sized button with
             margin to spare). Because the collapsed position itself hides
             everything, we can animate the close instead of snapping it -
             no visible=false toggle and no peeking sliver. -->
        <Group id="panel" translation="[-460, 0]">
            <Rectangle width="340" height="1080" color="0x0a0a0af0" />
            <Rectangle translation="[338, 0]" width="2" height="1080" color="0xff2424ff" opacity="0.7" />
            <ButtonGroup id="menuBg" translation="[20, 80]" layoutDirection="vert"
                         itemSpacings="[14]" minWidth="300" />
        </Group>

        <Animation id="expandAnim" duration="0.22" easeFunction="outQuad" repeat="false">
            <Vector2DFieldInterpolator id="expandInterp"
                key="[0, 1]"
                keyValue="[[-460, 0], [0, 0]]"
                fieldToInterp="panel.translation" />
        </Animation>
    </children>
</component>
